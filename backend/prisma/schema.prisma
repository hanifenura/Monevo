// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id        Int               @id @default(autoincrement())
  name           String
  email          String            @unique
  password_hash  String
  created_at     DateTime          @default(now())
  updated_at     DateTime          @default(now())
  lists          ShoppingList[]    @relation("UserLists")
  accesses       UserListAccess[]
  invitedAccess  UserListAccess[]  @relation("UserInvitedAccess")
  receipts       Receipt[]
  expenses       Expense[]
  checkedItems   ListItem[]        @relation("CheckedByUser")
  sharedLists    ShoppingListShare[]
}

model ShoppingList {
  list_id     Int               @id @default(autoincrement())
  owner_id    Int
  name        String?
  created_at  DateTime          @default(now())
  updated_at  DateTime          @default(now())
  is_shared   Boolean           @default(false)
  owner       User              @relation("UserLists", fields: [owner_id], references: [user_id], onDelete: Cascade)
  items       ListItem[]
  receipts    Receipt[]
  accesses    UserListAccess[]
  sharedWith  ShoppingListShare[]
}

model UserListAccess {
  access_id   Int      @id @default(autoincrement())
  user_id     Int
  list_id     Int
  role        Role
  invited_by  Int?
  joined_at   DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  list        ShoppingList @relation(fields: [list_id], references: [list_id], onDelete: Cascade)
  invitedBy   User?    @relation("UserInvitedAccess", fields: [invited_by], references: [user_id])
  @@unique([user_id, list_id])
}

model Category {
  category_id Int        @id @default(autoincrement())
  name        String     @unique
  color_code  String?    @unique
  created_at  DateTime   @default(now())
  items       ListItem[]
  expenses    Expense[]
}

model ListItem {
  item_id      Int        @id @default(autoincrement())
  list_id      Int
  category_id  Int?
  name         String
  quantity     Int        @default(1)
  price        Decimal?
  source       Source?    @default(manual)
  is_checked   Boolean    @default(false)
  created_at   DateTime   @default(now())
  checkedById  Int?
  checkedAt    DateTime?
  list         ShoppingList @relation(fields: [list_id], references: [list_id], onDelete: Cascade)
  category     Category?  @relation(fields: [category_id], references: [category_id])
  checkedBy    User?      @relation("CheckedByUser", fields: [checkedById], references: [user_id])
}

model Receipt {
  receipt_id      Int       @id @default(autoincrement())
  list_id         Int?
  user_id         Int
  store_name      String?
  total_amount    Decimal?
  subtotal        Decimal?
  receipt_date    DateTime?
  payment_method  PaymentMethod?
  tax_rate        Decimal?
  tax_amount      Decimal?
  currency        String     @default("TRY")
  image_url       String?
  ocr_text        String?
  processed       Boolean    @default(false)
  uploaded_at     DateTime   @default(now())
  list            ShoppingList? @relation(fields: [list_id], references: [list_id], onDelete: Cascade)
  user            User       @relation(fields: [user_id], references: [user_id])
  items           ReceiptItem[]
}

model ReceiptItem {
  id            Int       @id @default(autoincrement())
  receiptId     Int
  productName   String
  price         Decimal
  quantity      Decimal   @default(1)
  unit          String    @default("adet")
  pricePerUnit  Decimal?
  taxRate       Decimal?
  receipt       Receipt   @relation(fields: [receiptId], references: [receipt_id], onDelete: Cascade)
}

model Expense {
  expense_id   Int        @id @default(autoincrement())
  user_id      Int
  category_id  Int?
  total_amount Decimal
  month        Int
  year         Int
  created_at   DateTime   @default(now())
  user         User       @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  category     Category?  @relation(fields: [category_id], references: [category_id])
  @@unique([user_id, category_id, month, year])
}

model ShoppingListShare {
  id        Int          @id @default(autoincrement())
  list_id   Int
  user_id   Int
  role      Role
  list      ShoppingList @relation(fields: [list_id], references: [list_id], onDelete: Cascade)
  user      User         @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  @@unique([list_id, user_id])
}

enum Role {
  owner
  editor
  viewer
}

enum Source {
  manual
  ocr
}

enum PaymentMethod {
  cash
  card
  other
}